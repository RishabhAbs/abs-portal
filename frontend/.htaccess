<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Proxy API requests to the backend using [P] flag
  # This requires mod_proxy and mod_proxy_http to be enabled on the server
  RewriteCond %{REQUEST_URI} ^/api [NC]
  RewriteRule ^api/(.*)$ http://127.0.0.1:5000/api/$1 [P,L]

  RewriteCond %{REQUEST_URI} ^/uploads [NC]
  RewriteRule ^uploads/(.*)$ http://127.0.0.1:5000/uploads/$1 [P,L]

  # Don't touch files or directories that exist
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # React Router (Single Page App) catch-all
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>